flowchart LR
    subgraph DBs["MongoDB"]
            DB_STATUS[("Status Meeting<br>Collection")]
            DB_TIME[("Timetable<br>Collection")]
            DB_AGG[("Aggregations<br>Collection")]
        end
    subgraph Modify["Modify"]
        subgraph UpdateOne["Update_one"]
            Uo1["week_check"]
            Uo3["update_presence"]
            Uo6["_s5_get_data [error_unlock]"]
            subgraph Bulk_Group["DB_updater"]
                Uo2["handle_arrow"]
                Uo4["s4_update_hourly_goal"]
                Uo5["s4_update_days_goal"]
            end
        end
    end
    subgraph ModifyAndRead["Modify and Read"]
        subgraph FindAndUpdateOne["Find_and_update_one"]
            Fauo1["fetch_state"]
            Fauo2["_s5_get_data [lock]"]
            Fauo3["_s5_get_data [write]"]
        end
    end
    subgraph Reads["Read"]
        subgraph FindOne["Find_one"]
            Fo1["_fetch_discussion_points"]
            Fo2["s1_update_records_display"]
            Fo3["s4_fetch_goals"]
        end
        subgraph Find["Find"]
            F1["_fetch_logs"]
        end
        subgraph Aggregate["Aggregate"]
            A1["fetch_online_users_info"]
        end
        subgraph Watch["Watch"]
            W1["status_meeting_watcher"]
            W2["timetable_watcher"]
        end
    end

    Uo1 & Uo3 & Uo6 --> DB_STATUS
    Bulk_Group --> DB_STATUS
    DB_STATUS --> Fo1 & Fo3 & A1 & W1
    DB_TIME --> F1 & W2
    DB_AGG --> Fo2
    Fauo1 & Fauo2 & Fauo3 <--> DB_STATUS

    style Modify stroke:#000000,fill:#D50000,stroke-width:3px
    style DBs stroke:#000000,fill:#008000,stroke-width:3px
    style Reads stroke:#000000,fill:#0000FF,stroke-width:3px
    style ModifyAndRead stroke:#000000,fill:#990099,stroke-width:3px
    style Bulk_Group fill:#D50000,stroke:#000000,stroke-width:2px

    classDef sub_write fill:#FF1111,stroke:#000000,color:black, stroke-width:2px
    classDef sub_write_read fill:#CC00CC,stroke:#000000,color:black, stroke-width:2px
    classDef sub_read fill:#0070FF,stroke:#000000,color:black, stroke-width:2px

    class UpdateOne sub_write
    class FindAndUpdateOne sub_write_read
    class FindOne,Watch,Aggregate,Find sub_read
    %% def node classes %%
    classDef db fill:#f0f0f0,stroke:#000000,stroke-width:2px,color:black
    classDef write fill:#ffebee,stroke:#000000,color:black
    classDef writeread fill:#ffebee,stroke:#000000,color:black
    classDef read fill:#e1f5fe,stroke:#000000,color:black

    %% Assign nodes classes %%
    class DB_STATUS,DB_TIME,DB_AGG db
    class Uo1,Uo2,Uo3,Uo4,Uo5,Uo6 write
    class Fauo1,Fauo2,Fauo3 writeread
    class Fo1,Fo2,Fo3,W1,W2,A1,F1 read